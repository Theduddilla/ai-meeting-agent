# .env.example

# API Configuration
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Database Configuration
db_host=your_database_host

db_user=your_database_user

db_password=your_database_password

db_name=your_database_name

# LLM Providers
LLM_PROVIDER=your_llm_provider

# Transcription Services
TRANSCRIPTION_SERVICE_KEY=your_transcription_service_key

# Vector Database
VECTOR_DB_URL=your_vector_database_url

# Platform Integrations
PLATFORM_INTEGRATION_1_KEY=your_integration_1_key
PLATFORM_INTEGRATION_2_KEY=your_integration_2_key

# Monitoring
MONITORING_SERVICE_KEY=your_monitoring_service_key
